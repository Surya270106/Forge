FROM python:3.12-slim-bookworm

RUN groupadd --gid 10001 sandbox \
    && useradd \
        --uid 10001 \
        --gid 10001 \
        --create-home \
        --shell /usr/sbin/nologin \
        sandbox \
    && mkdir -p /workspace \
    && chown sandbox:sandbox /workspace

USER 10001:10001

WORKDIR /workspace

CMD ["python"]
